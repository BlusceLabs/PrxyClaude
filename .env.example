# ─────────────────────────────────────────────────────────────────────────────
# PrxyClaude · Environment Configuration
# ─────────────────────────────────────────────────────────────────────────────

# ── Server ───────────────────────────────────────────────────────────────────
PORT=8082
PROXY_AUTH_TOKEN=prxyclaude
ADMIN_TOKEN=admin-change-me
LOG_LEVEL=info

# ── API Keys ─────────────────────────────────────────────────────────────────
NVIDIA_NIM_API_KEY=
OPENROUTER_API_KEY=
LM_STUDIO_BASE_URL=

# ── Model mappings: provider_type/model_name ─────────────────────────────────
# Valid providers: nvidia_nim | open_router | lmstudio | groq | together | mistral | ollama | anthropic
MODEL_OPUS=nvidia_nim/stepfun-ai/step-3.7-flash
MODEL_SONNET=nvidia_nim/stepfun-ai/step-3.7-flash
MODEL_HAIKU=nvidia_nim/stepfun-ai/step-3.7-flash
MODEL=nvidia_nim/stepfun-ai/step-3.7-flash

# ── Provider config ──────────────────────────────────────────────────────────
PROVIDER_RATE_LIMIT=40
PROVIDER_RATE_WINDOW=60
PROVIDER_MAX_CONCURRENCY=5

# ── HTTP client timeouts (seconds) ───────────────────────────────────────────
HTTP_READ_TIMEOUT=120
HTTP_WRITE_TIMEOUT=10
HTTP_CONNECT_TIMEOUT=2
